# From Paynow dashboard → Receive Payment Links → your integration profile
PAYNOW_INTEGRATION_ID="123456"
PAYNOW_INTEGRATION_KEY="paste-your-integration-key-here"

# Public URLs reachable by Paynow (localhost is OK for redirect; resulturl webhook needs a tunnel for real callbacks)
PUBLIC_APP_ORIGIN="http://localhost:5173"
PUBLIC_API_ORIGIN="http://localhost:8787"

# Zimbabwe Paynow API endpoint (per Paynow Developer Hub)
PAYNOW_INIT_URL="https://www.paynow.co.zw/interface/initiatetransaction"
